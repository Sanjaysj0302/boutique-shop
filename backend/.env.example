# ========================================
# TWILIO CONFIGURATION
# ========================================
# Get these credentials from https://www.twilio.com/console
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890
MY_PHONE_NUMBER=+91XXXXXXXXXX

# ========================================
# SERVER CONFIGURATION
# ========================================
# Server port (for development)
PORT=3000
port=3000

# Server host
# Use 'localhost' for local development
# Use '0.0.0.0' for production to accept all connections
HOST=localhost

# Environment type
NODE_ENV=development

# ========================================
# DEPLOYMENT CONFIGURATION
# ========================================
# Frontend URL (for CORS policy)
# Set this when deploying to production
FRONTEND_URL=https://your-frontend-domain.com

# Your production domain (add to CORS whitelist)
# Example: https://nila-instyle.com
