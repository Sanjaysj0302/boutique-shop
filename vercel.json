{
  "version": 2,
  "installCommand": "cd react-app && npm install",
  "buildCommand": "cd react-app && npm run build",
  "outputDirectory": "react-app/build",
  "rewrites": [
    { "source": "/send-message", "destination": "/api/send-message" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
